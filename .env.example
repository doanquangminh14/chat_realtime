# Copy this file to .env and adjust values for local development
# Usage: export $(grep -v '^#' .env | xargs)

# Application
DS_APP_ENVIRONMENT=development
DS_APP_VERSION=1.0.0

# gRPC Server
DS_GRPC_HOST=0.0.0.0
DS_GRPC_PORT=50051
DS_GRPC_TIMEOUT=30s
DS_GRPC_MAX_RETRIES=3

# RabbitMQ
DS_RABBITMQ_URL=amqp://guest:guest@localhost:5672/
DS_RABBITMQ_EXCHANGE=calculator_events
DS_RABBITMQ_QUEUE=calculation_results
DS_RABBITMQ_ROUTING_KEY=calculation.result
DS_RABBITMQ_PREFETCH=10

# Chat Server
DS_CHAT_HOST=0.0.0.0
DS_CHAT_PORT=8080
DS_CHAT_MAX_CLIENTS=1000
DS_CHAT_MESSAGE_HISTORY=100

# Logging
DS_LOG_LEVEL=info
DS_LOG_FORMAT=json
# Use 'console' format for local dev with colored output
# DS_LOG_FORMAT=console
