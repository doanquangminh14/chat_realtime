# Multi-stage build for rpc-server
FROM golang:1.22-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /bin/rpc-server ./cmd/rpc-server

# Minimal runtime image
FROM scratch
COPY --from=builder /bin/rpc-server /rpc-server
COPY --from=builder /app/configs /configs

EXPOSE 50051
ENTRYPOINT ["/rpc-server"]
